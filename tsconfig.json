{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "./tests/**/*.ts",
    "./pages/**/*.ts",
    "./utils/**/*.ts",
    "./playwright.config.ts"
  ]
}
